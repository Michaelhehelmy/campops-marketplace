{
  "name": "@sinaicamps/marketplace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:full": "npm run dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "prettier --check . && npm run lint && npm run test",
    "check:full": "bash scripts/run-all-checks.sh",
    "test": "vitest run",
    "test:full": "npm run test:all",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=lcov",
    "test:all": "vitest run && npm run test --prefix templates/shop-frontend",
    "test:all:coverage": "vitest run --coverage && npm run test:coverage --prefix templates/shop-frontend",
    "test:e2e": "playwright test",
    "test:e2e:full": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.17",
    "jiti": "^2.7.0",
    "lucide-react": "^0.511.0",
    "next": "14.2.29",
    "next-intl": "^3.26.3",
    "pg": "^8.20.0",
    "plugin-engine": "^5.8.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "single-spa": "^6.0.3",
    "single-spa-react": "^6.0.2",
    "tapable": "^2.3.3",
    "ts-node": "^10.9.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "eslint": "8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
