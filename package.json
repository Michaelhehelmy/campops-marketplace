{
  "name": "@sinaicamps/marketplace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:full": "npm run dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "prettier --check . && npm run lint && npm run test",
    "check:full": "bash scripts/run-all-checks.sh",
    "test": "vitest run",
    "test:full": "npm run test:all",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run tests/api-smoke.test.ts",
    "test:all": "vitest run",
    "test:all:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "analyze": "ANALYZE=true next build",
    "perf:lighthouse": "node scripts/lighthouse-audit.mjs",
    "perf:bundle": "next build && npx next-bundle-analyzer"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.53.1",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.9.0",
    "chrome-launcher": "^1.2.1",
    "drizzle-orm": "^0.45.2",
    "form-data": "^4.0.5",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.17",
    "ioredis": "^5.10.1",
    "jiti": "^2.7.0",
    "lighthouse": "^13.3.0",
    "lucide-react": "^0.511.0",
    "lunr": "^2.3.9",
    "mailgun.js": "^13.0.1",
    "next": "14.2.29",
    "next-intl": "^3.26.3",
    "next-mdx-remote": "^6.0.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "plugin-engine": "^5.8.8",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "single-spa": "^6.0.3",
    "single-spa-react": "^6.0.2",
    "stripe": "^22.1.1",
    "tapable": "^2.3.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lunr": "^2.3.7",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "eslint": "8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "description": "> A white-label, multi-tenant hospitality marketplace. One platform powers your public listing site, property owner dashboards, and fully branded tenant shop frontends — all driven by a plugin ecosystem you control.",
  "main": "ecosystem.config.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelhehelmy/campops-marketplace.git"
  },
  "keywords": [],
  "author": "Michael Helmy",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/michaelhehelmy/campops-marketplace/issues"
  },
  "homepage": "https://github.com/michaelhehelmy/campops-marketplace#readme"
}
