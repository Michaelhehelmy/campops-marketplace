{
  "id": "camp-classic",
  "name": "Camp Classic",
  "version": "1.0.0",
  "author": "CampOps",
  "description": "Classic campsite shopfront with booking widget — default CampOps theme.",
  "supports": {
    "post_types": ["listing"],
    "features": ["dark-mode", "pwa"],
    "customColors": true,
    "customFonts": false
  },
  "entry": "templates/single-listing.tsx",
  "template_hierarchy": {
    "listing": "templates/single-listing.tsx",
    "page": "templates/page.tsx",
    "404": "templates/not-found.tsx"
  },
  "widget_areas": [
    { "id": "header", "label": "Header" },
    { "id": "footer", "label": "Footer" },
    { "id": "sidebar", "label": "Sidebar" }
  ],
  "custom_fields": [
    { "key": "price_per_night", "type": "number", "label": "Price per night" },
    { "key": "capacity", "type": "number", "label": "Capacity (guests)" },
    { "key": "amenities", "type": "json", "label": "Amenities" },
    { "key": "primary_image", "type": "text", "label": "Primary image URL" },
    { "key": "gallery", "type": "json", "label": "Gallery (JSON array)" },
    { "key": "check_in_time", "type": "text", "label": "Check-in time" },
    { "key": "check_out_time", "type": "text", "label": "Check-out time" }
  ],
  "plugin_dependencies": []
}
