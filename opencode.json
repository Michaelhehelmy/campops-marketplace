{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/next-devtools-mcp/dist/index.js"
      ],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "."
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/@modelcontextprotocol/server-github/dist/index.js"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/@playwright/mcp/cli.js"
      ],
      "enabled": true
    },
    "sqlite": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/mcp-server-sqlite/dist/index.js",
        "--db",
        "./sinaicamps.db"
      ],
      "enabled": true
    },
    "tailwindcss": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/tailwindcss-mcp/dist/index.js"
      ],
      "enabled": true
    },
    "lucide-icons": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/lucide-icons-mcp/build/entry.js",
        "--stdio"
      ],
      "enabled": true
    },
    "next-intl": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/@i18nexus/mcp/dist/index.js"
      ],
      "enabled": true
    },
    "lighthouse": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/tsx/dist/cli.mjs",
        "packages/mcp-server-lighthouse/src/index.ts"
      ],
      "enabled": true
    },
    "better-auth": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/tsx/dist/cli.mjs",
        "packages/better-auth-mcp/src/index.ts"
      ],
      "enabled": true
    },
    "email": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/tsx/dist/cli.mjs",
        "packages/mcp-server-mailgun/src/index.ts"
      ],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/@cyanheads/git-mcp-server/dist/index.js"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/markfetch/dist/index.js"
      ],
      "enabled": true
    },
    "ripgrep": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/ripgrep-mcp/dist/index.js"
      ],
      "enabled": true
    },
    "everything": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/@modelcontextprotocol/server-everything/dist/index.js"
      ],
      "enabled": true
    },
    "pdf": {
      "type": "local",
      "command": [
        "node",
        ".opencode/node_modules/@modelcontextprotocol/server-pdf/dist/index.js",
        "--stdio"
      ],
      "enabled": true
    }
  },
  "agent": {
    "deploy": {
      "description": "SinaiCamps deployment specialist — build locally and push to server",
      "system": "You are the SinaiCamps deployment agent. Your ONLY job is building and deploying the application.\n\nRules:\n- Always build first using standard framework build steps\n- Deploy via: .&#x2F;scripts&#x2F;deploy-sinaicamps.sh\n- Confirm success by checking server processes and logs\n- Use the deploy-to-server skill for step-by-step guidance"
    },
    "qa": {
      "description": "SinaiCamps QA agent — run tests, find and fix failures",
      "system": "You are the SinaiCamps QA agent. Your job is ensuring all tests pass.\n\nRules:\n- Always run unit or E2E tests before marking anything done\n- Use available E2E test tools to verify UI behaviour visually\n- Target: 100% test pass rate, verify coverage guidelines\n- Never skip a failing test — fix the root cause"
    },
    "db": {
      "description": "SinaiCamps database agent — schema changes and data queries",
      "system": "You are the SinaiCamps database agent. You handle all database work.\n\nRules:\n- NEVER write raw SQL strings in application code if an ORM is available\n- EVERY schema change requires a migration file\n- ALWAYS scope tenant queries by site_id/tenant_id to avoid data leaks\n- Use the sqlite or SQL MCP to inspect live data\n- NEVER DROP TABLE without explicit user confirmation\n- Use the db-migration skill for the full checklist"
    },
    "plugin-dev": {
      "description": "SinaiCamps plugin developer — scaffold and build new plugins",
      "system": "You are the SinaiCamps plugin developer. You build modular extensions.\n\nRules:\n- Follow the plugin contract for the project\n- NEVER hardcode business logic in core — keep it modular\n- Always add unit tests for new modules\n- Use the create-feature skill for the full checklist"
    }
  },
  "lsp": {
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    },
    "tailwindcss": {
      "command": [
        "tailwindcss-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".css"
      ]
    },
    "json": {
      "command": [
        "vscode-json-language-server",
        "--stdio"
      ],
      "extensions": [
        ".json",
        ".jsonc"
      ]
    },
    "html": {
      "command": [
        "vscode-html-language-server",
        "--stdio"
      ],
      "extensions": [
        ".html"
      ]
    },
    "css": {
      "command": [
        "vscode-css-language-server",
        "--stdio"
      ],
      "extensions": [
        ".css"
      ]
    },
    "markdown": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "plugin": []
}