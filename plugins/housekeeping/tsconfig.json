{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "paths": {
      "campops-sdk": ["../../packages/plugin-sdk/src/types.ts"],
      "@campops/plugin-sdk": ["../../packages/plugin-sdk/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"],
  "references": [
    {
      "path": "../../packages/plugin-sdk"
    }
  ]
}
