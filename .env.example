# ─── Acacia Camp Backend ──────────────────────────────────────────────────────
# URL of the running Acacia Camp Express API
NEXT_PUBLIC_API_URL=http://localhost:5000

# URL of the Acacia Camp admin SPA (Vite dev server or built static files)
# Used to proxy /admin/* requests to the full operations panel
ADMIN_SPA_URL=http://localhost:3000

# ─── Multi-tenant / Subdomain Routing ────────────────────────────────────────
# Your root domain — subdomains like campname.campops.com are resolved against this
NEXT_PUBLIC_BASE_DOMAIN=campops.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must match JWT_SECRET in your Acacia Camp backend
# (Only needed if you validate tokens server-side inside Next.js)
JWT_SECRET=change-me-to-a-long-random-string

# ─── Optional: Stripe (premium plan payments) ────────────────────────────────
# Public key is safe to expose; secret key must never be committed
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY is handled server-side in the Acacia Camp backend only

# ─── Optional: Analytics ─────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
