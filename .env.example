# CampOps Marketplace - Environment Variables

# Node Environment
NODE_ENV=development

# Authentication (better-auth)
BETTER_AUTH_SECRET=your-super-secret-auth-key-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# Database
# For SQLite (Development/Testing):
# Leave DATABASE_URL empty to use campops.db locally.
# DATABASE_URL=

# For PostgreSQL (Production):
# DATABASE_URL=postgresql://user:password@localhost:5432/campops

# Domain / DNS Provisioning (Required for Premium subdomains and Ultimate custom domains)
# See domain-provisioning.ts for full details.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
SERVER_IP=
ADMIN_EMAIL=

# Paymob Payment Gateway (required for Paymob plugin)
# Get from: https://accept.paymob.com → Settings → Account Info / Integrations
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# Google OAuth (optional — enables "Sign in with Google")
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must include: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (required for premium/ultimate plan billing)
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Prometheus metrics endpoint token
METRICS_TOKEN=your-secure-random-token-here
# Grafana admin password
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password
# Alert webhook (Telegram/Slack/PagerDuty)
ALERT_WEBHOOK_URL=https://hooks.slack.com/...

# HMAC key for role cookie signing — must be 32+ random chars
COOKIE_SIGNING_SECRET=generate-with-openssl-rand-base64-32

# Set to 'true' in development to bypass Stripe payment on plan upgrades
# SKIP_PAYMENT_GATE=true
