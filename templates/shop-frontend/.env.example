# Frontend Environment Variables

# Backend Marketplace API URL (Central Source of Truth)
VITE_API_BASE=http://localhost:3001
VITE_API_URL=http://localhost:3001

# WebSocket Server URL
VITE_WS_URL=http://localhost:5000

# ─── Branding (build-time fallbacks) ─────────────────────────────────────────
# The frontend fetches live branding from /api/branding on load.
# These VITE_ vars are used as immediate fallbacks before the API responds.
VITE_APP_NAME=
VITE_APP_SHORT_NAME=
VITE_COMPANY_NAME=
VITE_APP_TAGLINE=
VITE_APP_LOGIN_LABEL=
VITE_APP_LOGO_URL=
VITE_APP_FAVICON_URL=
VITE_APP_PRIMARY_COLOR=
VITE_APP_ACCENT_COLOR=
VITE_APP_BACKGROUND_COLOR=
VITE_CONTACT_EMAIL=
VITE_CONTACT_PHONE=
VITE_DOMAIN=
VITE_GOOGLE_CLIENT_ID=
