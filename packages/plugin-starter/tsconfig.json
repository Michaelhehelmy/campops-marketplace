{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "paths": {
      "sinaicamps-sdk": ["../../packages/plugin-sdk/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
