{
  "name": "@sinaicamps/plugin-sdk",
  "version": "2.0.0",
  "description": "TypeScript types and interfaces for building SinaiCamps plugins",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "keywords": [
    "sinaicamps",
    "plugin",
    "sdk",
    "types"
  ],
  "license": "MIT"
}
